# MediCare Pharmacy - Environment Variables Example
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Payment Gateway
VITE_JAZZCASH_MERCHANT_ID=your_merchant_id
VITE_JAZZCASH_PASSWORD=your_password
VITE_JAZZCASH_RETURN_URL=https://yourdomain.com/payment/callback

VITE_EASYPAISA_STORE_ID=your_store_id
VITE_EASYPAISA_API_KEY=your_api_key

# Google Services
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Social Media OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# File Upload
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Email Service
VITE_EMAIL_SERVICE_URL=https://api.emailservice.com
VITE_EMAIL_API_KEY=your_email_api_key

# SMS Service
VITE_SMS_API_URL=https://api.smsservice.com
VITE_SMS_API_KEY=your_sms_api_key

# Feature Flags
VITE_ENABLE_PRESCRIPTION_UPLOAD=true
VITE_ENABLE_LAB_TESTS=true
VITE_ENABLE_ONLINE_CONSULTATION=true
VITE_ENABLE_CHAT_SUPPORT=true

# App Configuration
VITE_APP_NAME=MediCare
VITE_APP_URL=https://medicare.pk
VITE_SUPPORT_EMAIL=support@medicare.pk
VITE_SUPPORT_PHONE=+92-300-1234567

# Delivery Configuration
VITE_EXPRESS_DELIVERY_TIME=2
VITE_STANDARD_DELIVERY_TIME=24
VITE_FREE_DELIVERY_THRESHOLD=2000

# Currency
VITE_CURRENCY=PKR
VITE_CURRENCY_SYMBOL=Rs.

# Environment
VITE_ENV=development
